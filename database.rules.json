{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "rooms": {
      "$room": {
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || data.child('createdBy').val() === auth.uid)"
        },
        "players": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            "message": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 15)"
            }
          }
        },
        "connections": {
          ".read": "auth != null",
          "$connId": {
            ".write": "auth != null && $connId.contains(auth.uid)"
          }
        }
      }
    }
  }
}
