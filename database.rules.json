{
  "_comment": "本番向けルール: 匿名認証(auth)済みユーザーのみ。自分のアバターは自分だけが書き込み可。通話シグナリングは当事者のみ。",
  "rules": {
    "rooms": {
      "$room": {
        "players": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "connections": {
          ".read": "auth != null",
          "$connId": {
            ".write": "auth != null && $connId.contains(auth.uid)"
          }
        }
      }
    }
  }
}
